{
    "manifest_version": 3,
    "name": "Ar Condicionado",
    "version": "1.2",
    "description": "Escolha o tipo, BTUs e ciclo e vá direto para a lista de ar-condicionados da Dufrio ou Leveros, com acessos rápidos ao carrinho e às páginas de produtos.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "https://www.dufrio.com.br/*",
        "https://www.leveros.com.br/*",
        "https://parceiro.centralar.com.br/*",
        "https://opensheet.elk.sh/*",
        "https://castaticstorage.blob.core.windows.net/*"
    ],
    "externally_connectable": {
        "matches": [
            "https://crftwoo.github.io/*",
            "http://127.0.0.1:*/*",
            "http://localhost:*/*"
        ]
    },
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Pesquisa de Ar Condicionado"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.dufrio.com.br/ar-condicionado*",
                "https://www.vendas.leveros.com.br/ar-condicionado*",
                "https://parceiro.centralar.com.br/*"
            ],
            "css": [
                "content.css"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://www.dufrio.com.br/checkout/cart/*",
                "https://www.vendas.leveros.com.br/checkout/carrinho*"
            ],
            "css": [
                "cart.css"
            ],
            "js": [
                "cart.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://crftwoo.github.io/*",
                "http://127.0.0.1:*/*",
                "http://localhost:*/*",
                "file:///*"
            ],
            "js": [
                "bridge.js"
            ],
            "run_at": "document_start",
            "all_frames": true
        }
    ]
}